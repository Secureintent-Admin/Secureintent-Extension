# WXT build-time env. Vars prefixed WXT_ are exposed via import.meta.env.
# Clerk publishable key (NOT a secret, but instance-specific). Fill in once the
# Clerk instance exists: Clerk Dashboard → API Keys → Publishable key.
WXT_CLERK_PUBLISHABLE_KEY=pk_live_Y2xlcmsuc2VjdXJlaW50ZW50LmFpJA

# Clerk Frontend API custom domain — the extension Sync Host reads the prod
# session cookie from here (NOT the app root). Must be in host_permissions.
WXT_CLERK_SYNC_HOST=https://clerk.secureintent.ai
# App origin where account.html / sign-in UI are served.
WXT_WEB_APP_URL=https://secureintent.ai

# Google OAuth client id (Web application type) for chrome.identity sign-in.
# Create it in Google Cloud Console → Credentials → OAuth client ID → Web app,
# and add the redirect URI: https://gpaibfnbfnfhiodfkffiajmoemhbfief.chromiumapp.org/
# Must match backend GOOGLE_CLIENT_ID. Leave empty to hide the Google button.
WXT_GOOGLE_CLIENT_ID=2181914179-6839u7jjldbaf5mp2e9ika8is7gcja3s.apps.googleusercontent.com
